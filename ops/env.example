OPENBORME_SQLITE_PATH=
OPENBORME_SQLITE_SOURCE_PATH=
OPENBORME_WEB_READ_ONLY=1

# Runtime DB: sqlite (default) | pgsql
OPENBORME_DB_DRIVER=sqlite

# Opción A (recomendada): DSN completo
OPENBORME_DB_DSN=
OPENBORME_DB_USER=
OPENBORME_DB_PASS=

# Opción B (si no usas DSN)
OPENBORME_PG_HOST=
OPENBORME_PG_PORT=5432
OPENBORME_PG_DBNAME=
OPENBORME_PG_USER=
OPENBORME_PG_PASS=

OPENBORME_FTP_HOST=
OPENBORME_FTP_USER=
OPENBORME_FTP_PASS=

# ops/sync_data.py
OPENBORME_SYNC_FILES=pipeline/data/openborme.sqlite
OPENBORME_SYNC_REMOTE_DIR=pipeline/data

# ops/deploy_prod.py
OPENBORME_LOCAL_WEB_ROOT=
OPENBORME_LOCAL_PIPELINE_ROOT=

# ops/ftp_deploy.py
OPENBORME_LEGACY_DEPLOY_DIR=
OPENBORME_LEGACY_DEPLOY_ITEMS=public_html,pipeline,docs,ops,README.md,LICENSE,CONTRIBUTING.md
